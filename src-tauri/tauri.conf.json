{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ByType",
  "version": "0.1.0",
  "identifier": "com.bytype.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ByType",
        "width": 900,
        "height": 640,
        "visible": false
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "width": 240,
        "height": 64,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "shadow": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
